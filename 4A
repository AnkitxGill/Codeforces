// Watermelon Problem
#include<stdio.h>
#include<conio.h>

int main()
{
    int w;
    scanf("%d", &w); // weight of watermelon
    if( 4 <= w <= 100)
    {
        if(w % 2 == 0)
        {
            printf("YES");
        }   
        else
        {
            printf("NO");
        }
    }
    else
    {
        printf("NO");
    }
    return 0;
}
